---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getAllPosts } from '../../lib/blog-api';

const posts = await getAllPosts();
---

<Layout
  title="SMSF Blog"
  description="Expert insights, tips, and updates on Self-Managed Super Funds from the team at Magnified SMSF Specialists."
>
  <div class="space-y-0 pb-24">
    <section class="hero-bg-blog overflow-hidden bg-cover bg-center py-20 text-white">
      <div class="px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-7xl text-center">
          <h1 class="text-4xl font-bold md:text-5xl lg:text-6xl">SMSF Insights & Articles</h1>
          <p class="mx-auto mt-6 max-w-3xl text-lg text-white/90 md:text-xl">Expert guidance and practical advice to help you take confident control of your Self-Managed Super Fund.</p>
        </div>
      </div>
    </section>

    <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        {posts.length === 0 ? (
          <div class="py-16 text-center">
            <p class="text-xl text-neutral-500">No blog posts yet. Check back soon.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => <BlogCard post={post} />)}
          </div>
        )}
      </div>
    </section>
  </div>
</Layout>
