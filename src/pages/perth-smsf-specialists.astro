---
import Layout from '../layouts/Layout.astro';
import LocationPageLayout from '../components/modules/LocationPageLayout.astro';
---

<Layout
  title="SMSF Accountants Perth | SMSF Specialists WA"
  description="SMSF accountants and specialists supporting Perth trustees with setup, administration, annual returns, compliance and tax planning. Book a free discovery session."
>
  <LocationPageLayout
    locationName="Perth Metro"
    heroTitle="SMSF Accountants & Specialists in Perth"
    heroImage="/images/smsf-specialists-perth-mandurah-hero.jpg"
    heroSubheading="Take confident control of your self managed super fund with Perth SMSF accountants and specialists focused on compliance, administration and practical trustee support."
    trustedPartnerText="At Magnified SMSF Specialists, we're your dedicated SMSF accounting and compliance team for the Perth metropolitan area. We understand the unique demands and financial aspirations of successful Australians in Perth, offering personalised SMSF solutions designed to support your retirement goals and provide absolute peace of mind. Managing your super shouldn't feel overwhelming, and we're here to help you navigate SMSF setup, annual returns, administration, tax planning and compliance obligations with clarity."
    servicesIntro="From initial SMSF setup and registration to annual returns, ongoing administration, compliance, pension phase support and investment strategy documentation, Magnified SMSF Specialists offers services designed to simplify your SMSF journey across Perth."
    localSeoTitle="Perth SMSF Accountant Support Without the Guesswork"
    localSeoText="Our Mandurah-based team supports Perth trustees online and in person, combining CPA practice standards, SAN AFSL credentials and specialist SMSF experience for clients who want clear accounting, compliance and administration support."
    localSeoItems={[
      'SMSF setup, registration and establishment guidance',
      'Annual SMSF return, financial statements and tax return support',
      'ATO compliance, audit support and trustee record keeping',
      'Tax planning, pension phase and contribution guidance',
      'Investment strategy documentation and regular compliance reviews',
      'Support for Perth trustees who prefer local WA SMSF specialists',
    ]}
    isThisYouIntro="At Magnified SMSF Specialists, we empower SMSF trustees and future trustees in Perth Metro who want clarity and confidence managing their super. Our services are ideally suited for individuals who:"
    whyTrustsIntro="Perth Metro trusts Magnified SMSF Specialists for SMSF guidance that truly fits their needs and aspirations."
    dedicatedSupportText="Enjoy personalised assistance from our Mandurah-based SMSF accountant and specialist team, with online and in-person support available for Perth metropolitan trustees."
    trustedByText="Join the many professionals in Perth Metro who rely on our trusted SMSF accounting, compliance and administration support."
    contactIntro="Ready to gain clarity and confidence in your SMSF? We invite you to experience the expertise and personalised service that distinguishes us as a trusted Perth SMSF accountant and specialist partner."
  />
</Layout>
