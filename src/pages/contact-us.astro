---
import Layout from '../layouts/Layout.astro';
import ContactSection from '../components/modules/ContactSection.astro';
import MapSection from '../components/modules/MapSection.astro';
import { siteConfig } from '../config/site';
---

<Layout
  title="Contact Magnified SMSF Specialists"
  description="Get in touch with Perth & Mandurah's SMSF specialists. Call +61 (8) 9456 0010, email info@magnifiedsmsf.com.au, or visit Unit 2/106 Pinjarra Road, Mandurah WA 6210."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/contact-smsf-specialists-mandurah.jpg"
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-[#b8bcbb]/75 backdrop-blur-sm"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-primary-500 mb-2">
          Get in <span class="text-accent-500">Touch</span>
        </h1>
        <p class="text-lg text-primary-500/80 font-light">
          Have a question or ready to get started? Our specialist team is here to help.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Form & Details -->
  <ContactSection
    title="Contact Magnified SMSF Specialists"
    description="Our specialist team is here to provide expert guidance and support for your retirement journey."
  />

  <!-- Map -->
  <MapSection />
</Layout>
