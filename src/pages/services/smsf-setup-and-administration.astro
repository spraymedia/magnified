---
import Layout from '../../layouts/Layout.astro';
import ServicePageLayout from '../../components/modules/ServicePageLayout.astro';
---

<Layout
  title="SMSF Registration, Setup & Administration"
  description="SMSF registration, setup and administration support for Perth and Mandurah trustees, including trust deed, ABN, TFN, rollovers and ongoing compliance."
>
  <ServicePageLayout
    heroImage="/images/smsf-specialists-about-banner.jpg"
    heroTitle="SMSF Setup and"
    heroTitleAccent="Administration"
    heroDescription="Setting up and managing a Self-Managed Super Fund (SMSF) can seem daunting, but with Magnified SMSF Specialists, it becomes a clear, structured process. We guide trustees through SMSF registration, trust deed setup, corporate trustee decisions, ABN and TFN applications, bank account setup, rollovers, investment strategy documentation and day-to-day administration so your fund starts and stays aligned with Australian Taxation Office (ATO) requirements."
    servicesTitle="What Our SMSF Setup & Administration Service Includes"
    servicesIntro="Practical establishment and administration support for Perth, Mandurah and regional WA trustees who want their SMSF set up correctly from day one."
    serviceCards={[
      {
        title: 'SMSF Registration & Establishment',
        description: 'Guidance on trust deed preparation, corporate trustee structure, ATO registration, and obtaining ABN and TFN details.',
      },
      {
        title: 'Bank Account, Rollover & Setup Steps',
        description: 'Help coordinating establishment steps including SMSF bank account setup, contribution planning, rollover administration and initial trustee records.',
      },
      {
        title: 'Ongoing SMSF Administration',
        description: 'Handling member records, contribution tracking, compliance reporting, annual financial statements and regular administration tasks.',
      },
      {
        title: 'Compliance & Investment Strategy Records',
        description: 'Keeping trustee records, investment strategy documentation and annual obligations organised so your SMSF remains compliant.',
      },
    ]}
    ctaText="Ready to ensure your SMSF is set up for seamless operation and ongoing compliance?"
    ctaButton="Get Setup & Admin Support"
    whyChooseTitle="Why Choose Magnified SMSF Specialists for Your SMSF Journey?"
    whyChooseIntro="When it comes to securing your retirement, choosing the right SMSF specialist is paramount. Here's why successful Australians across Perth and Mandurah trust Magnified SMSF Specialists"
    whyChooseCards={[
      {
        title: 'Over 18 Years of Exclusive SMSF Expertise',
        description: 'Benefit from unmatched experience in Self-Managed Super Funds, ensuring expert guidance tailored to your needs.',
      },
      {
        title: 'Dedicated Local Support Team',
        description: 'Enjoy personalised assistance from a Perth-based team that truly understands your SMSF requirements.',
      },
      {
        title: 'Trusted by Leading Perth Professionals',
        description: 'Join the many professionals in Perth who rely on our trusted advice and superior service.',
      },
      {
        title: 'Personalised, Proactive Care',
        description: 'We deliver proactive client care valued by SMSF trustees across Western Australia.',
      },
    ]}
    faqs={[
      {
        question: 'How long does it take to set up an SMSF?',
        answer: 'Setting up an SMSF typically takes 2-4 weeks, depending on factors like obtaining your ABN and TFN. With our efficient processes, we ensure your SMSF is ready to operate quickly and hassle-free.',
      },
      {
        question: 'What does SMSF registration involve?',
        answer: 'SMSF registration generally involves establishing the trust deed, deciding trustee structure, registering with the ATO, applying for ABN and TFN details, opening a bank account, arranging rollovers and documenting the fund investment strategy.',
      },
      {
        question: 'What documents do I need to set up an SMSF?',
        answer: "You'll need identification documents, a trust deed, and bank account details. Our team will guide you step-by-step to ensure nothing is overlooked.",
      },
      {
        question: 'Can I set up an SMSF if I\'m self-employed?',
        answer: "Absolutely! SMSFs are a great option for self-employed individuals looking to take control of their retirement savings.",
      },
    ]}
    bottomCtaText="Let Magnified SMSF Specialists help you set up and manage your SMSF with ease and expertise. We're ready to provide a personalised solution that aligns perfectly with your retirement aspirations."
    bottomCtaButton="Get help setting up your SMSF"
  />
</Layout>
