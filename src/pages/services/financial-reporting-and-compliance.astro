---
import Layout from '../../layouts/Layout.astro';
import ServicePageLayout from '../../components/modules/ServicePageLayout.astro';
---

<Layout
  title="SMSF Compliance Specialists Mandurah & Perth"
  description="SMSF compliance specialists supporting Mandurah and Perth trustees with annual returns, financial statements, ATO records, audit support and Class Super reporting."
>
  <ServicePageLayout
    heroImage="/images/smsf-specialists-about-banner.jpg"
    heroTitle="SMSF Financial Reporting and"
    heroTitleAccent="Compliance"
    heroDescription="Managing your SMSF's financial reporting and compliance can be overwhelming, but at Magnified SMSF Specialists, we make it simple. Our team helps prepare annual financial statements, SMSF annual returns, tax records, contribution and pension records, and the documentation required for independent audit review. Using advanced tools like Class Super software, we provide clear reporting and practical support to help your fund meet ATO compliance obligations every step of the way."
    servicesTitle="Key Financial Reporting & Compliance Services We Offer"
    servicesIntro="We provide comprehensive support to keep your SMSF transparent, accurate, organised and aligned with ATO requirements:"
    serviceCards={[
      {
        title: 'Annual SMSF Return & Financial Statements',
        description: "Annual SMSF return support and financial statements that give a clear snapshot of your fund's performance and obligations.",
      },
      {
        title: 'ATO Compliance & Tax Records',
        description: 'Accurate tax, contribution, pension and member records to help your SMSF meet ATO deadlines and reporting requirements.',
      },
      {
        title: 'Independent Audit Support',
        description: 'Organised workpapers, reports and trustee records to support the independent SMSF audit process and resolve queries efficiently.',
      },
      {
        title: 'Class Super Reporting',
        description: "Access to your SMSF's financial data through the Class Super client portal, supporting informed trustee decisions and regular compliance reviews.",
      },
    ]}
    ctaText="Ready to ensure your SMSF is fully compliant and transparent?"
    ctaButton="Get Reporting & Compliance Support"
    whyChooseTitle="Why Choose Magnified SMSF Specialists for SMSF Compliance?"
    whyChooseIntro="When safeguarding your SMSF through diligent financial reporting and compliance, choosing a trusted partner makes all the difference."
    whyChooseCards={[
      {
        title: 'Over 18 Years of Exclusive SMSF Expertise',
        description: 'Benefit from unmatched experience in Self-Managed Super Funds, ensuring expert guidance tailored to your needs.',
      },
      {
        title: 'Dedicated Local Support Team',
        description: 'Enjoy personalised assistance from a Perth-based team that truly understands your SMSF requirements.',
      },
      {
        title: 'Trusted by Leading Perth Professionals',
        description: 'Join the many professionals in Perth who rely on our trusted advice and superior service.',
      },
      {
        title: 'Advanced Technology',
        description: 'Access real-time insights through our Class Super client portal for informed decision-making.',
      },
    ]}
    faqs={[
      {
        question: "What's included in SMSF financial reporting?",
        answer: 'SMSF financial reporting commonly includes annual financial statements, member contribution records, pension records, tax schedules and the SMSF annual return.',
      },
      {
        question: 'Do you complete the independent SMSF audit?',
        answer: 'An SMSF audit must be completed by an independent approved SMSF auditor. We help prepare the records, reports and supporting documents needed for the audit process.',
      },
      {
        question: 'How often do I need to update my SMSF financial records?',
        answer: 'Regular updates are essential. We recommend quarterly tracking, which is included in our regular administration services.',
      },
      {
        question: 'What happens if my SMSF is non-compliant?',
        answer: 'Non-compliance can lead to fines and penalties. We identify issues early and resolve them to bring your fund back on track.',
      },
    ]}
    bottomCtaText="Don't let SMSF financial reporting and compliance become a burden. Stay on top of your SMSF obligations with Magnified SMSF Specialists. Our team is ready to provide you with a tailored solution to meet your needs and ensure your peace of mind."
    bottomCtaButton="Stay Compliant with Expert Reporting"
  />
</Layout>
