---
import Layout from '../layouts/Layout.astro';
import SectionWrapper from '../components/ui/SectionWrapper.astro';
import Button from '../components/ui/Button.astro';
import { siteConfig } from '../config/site';
---

<Layout title="Thank You" description="Thank you for contacting Magnified SMSF Specialists. We'll be in touch shortly.">
  <SectionWrapper bgColor="white">
    <div class="max-w-2xl mx-auto text-center py-12">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-accent-50 text-accent-500 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"></path>
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-primary-500 mb-4">Thank You for Getting in Touch</h1>
      <p class="text-neutral-600 text-lg mb-8">
        We've received your message and our specialist team will get back to you within 1 business day.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/" variant="primary" size="lg">
          Back to Home
        </Button>
        <Button href={`tel:${siteConfig.phoneHref}`} variant="outline" size="lg">
          Call Us Now: {siteConfig.phone}
        </Button>
      </div>
    </div>
  </SectionWrapper>
</Layout>
